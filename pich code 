import 'package:flutter/material.dart';
import 'package:fl_chart/fl_chart.dart';
import '../../../../core/constants/app_colors.dart';

class ModulationGraph extends StatelessWidget {
  final List<double> pitchHistory;

  const ModulationGraph({super.key, required this.pitchHistory});

  @override
  Widget build(BuildContext context) {
    // Generate data configurations directly from live controller tracking ticks
    final graphSpots = List<FlSpot>.generate(
      pitchHistory.length,
      (index) => FlSpot(index.toDouble(), pitchHistory[index]),
    );

    return Container(
      height: 110,
      padding: const EdgeInsets.all(12),
      decoration: BoxDecoration(
        color: AppColors.surface.withValues(alpha: 0.7),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: AppColors.primary.withValues(alpha: 0.2)),
      ),
      child: LineChart(
        LineChartData(
          gridData: const FlGridData(show: false),
          titlesData: const FlTitlesData(show: false),
          borderData: FlBorderData(show: false),
          minX: 0,
          maxX: pitchHistory.isEmpty ? 10 : (pitchHistory.length - 1).toDouble(),
          minY: 0,
          maxY: 1.0,
          lineBarsData: [
            LineChartBarData(
              spots: graphSpots.isEmpty ? const [FlSpot(0, 0.5)] : graphSpots,
              isCurved: true,
              color: AppColors.primary,
              barWidth: 3,
              isStrokeCapRound: true,
              dotData: const FlDotData(show: false),
              belowBarData: BarAreaData(
                show: true,
                color: AppColors.primary.withValues(alpha: 0.15),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
